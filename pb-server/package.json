{
	"name": "pb-server",
	"version": "1.0.0",
	"description": "",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src",
		"format": "prettier --write \"src/**/*.ts\"",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio --port 4985",
		"start": "node dist/index.js",
		"worker:vote": "node dist/workers/vote.worker.js",
		"dev": "tsc-watch --onSuccess \"node dist/index\"",
		"dev:worker": "tsx src/workers/vote.worker.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"dependencies": {
		"@socket.io/redis-adapter": "^8.3.0",
		"bullmq": "^5.76.10",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"express": "^5.2.1",
		"ioredis": "^5.10.1",
		"pg": "^8.20.0",
		"socket.io": "^4.8.3",
		"zod": "^4.4.3",
		"cors": "^2.8.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/node": "^25.7.0",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.7.0",
		"prettier": "3.8.3",
		"tsc-watch": "^7.2.0",
		"tsx": "^4.21.0",
		"typescript-eslint": "^8.59.3"
	}
}
